generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ADVISER
  CASE_MANAGER
}

enum ClientStatus {
  NEW_LEAD
  CONTACT_ATTEMPTED
  CALL_BACK
  QUALIFIED
  DOCS_REQUESTED
  DOCS_RECEIVED
  SUBMITTED
  APPROVED
  COMPLETED
  LOST
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  OPEN
  DONE
}

enum TaskOutcome {
  COMPLETED
  NO_ANSWER
  RESCHEDULED
  CANCELLED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(ADVISER)
  isActive     Boolean    @default(true)
  clients      Client[]
  notes        Note[]
  tasks        Task[]
  activities   Activity[] @relation("UserActivities")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ApiPartner {
  id          String     @id @default(cuid())
  name        String
  apiKeyHash  String
  isActive    Boolean    @default(true)
  allowedIps  String[]
  events      ApiEvent[]
  activities  Activity[] @relation("PartnerActivities")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Client {
  reference        Int?
  id               String       @id @default(cuid())
  externalId       String?
  title            String?
  firstName        String
  lastName         String
  email            String?
  mobile           String?
  clientSalary     String?
  propertyValue    String?
  dob              DateTime?
  addressLine1     String?
  addressLine2     String?
  city             String?
  county           String?
  postcode         String?
  source           String?
  campaign         String?
  status           ClientStatus @default(NEW_LEAD)
  assignedUser     User?        @relation(fields: [assignedUserId], references: [id])
  assignedUserId   String?
  consentEmail     Boolean      @default(false)
  consentSms       Boolean      @default(false)
  consentPhone     Boolean      @default(false)
  metadataJson     Json?
  notes            Note[]
  tasks            Task[]
  activities       Activity[]
  documents        Document[]
  clientDocuments  ClientDocument[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Task {
  id             String       @id @default(cuid())
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId       String?
  assignedUser   User?        @relation(fields: [assignedUserId], references: [id])
  assignedUserId String?
  title          String
  description    String?
  dueAt          DateTime?
  priority       TaskPriority @default(MEDIUM)
  status         TaskStatus   @default(OPEN)
  outcome        TaskOutcome?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Note {
  id         String   @id @default(cuid())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  body       String
  sourceType String   @default("internal")
  createdAt  DateTime @default(now())
}

model Activity {
  id                String      @id @default(cuid())
  client            Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId          String
  actorUser         User?       @relation("UserActivities", fields: [actorUserId], references: [id])
  actorUserId       String?
  actorApiPartner   ApiPartner? @relation("PartnerActivities", fields: [actorApiPartnerId], references: [id])
  actorApiPartnerId String?
  type              String
  description       String
  payloadJson       Json?
  createdAt         DateTime    @default(now())
}

model Document {
  id               String   @id @default(cuid())
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId         String
  uploadedByUserId String?
  fileName         String
  storageKey       String
  mimeType         String
  category         String?
  createdAt        DateTime @default(now())
}

model ApiEvent {
  id           String     @id @default(cuid())
  apiPartner   ApiPartner @relation(fields: [apiPartnerId], references: [id])
  apiPartnerId String
  endpoint     String
  method       String
  requestId    String
  statusCode   Int
  payloadJson  Json?
  responseJson Json?
  createdAt    DateTime   @default(now())
}

model ClientDocument {
  id           String   @id @default(cuid())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  section      String
  originalName String
  storedName   String
  mimeType     String?
  sizeBytes    Int?
  filePath     String
  autoTag      String?
  createdAt    DateTime @default(now())
}


model Template {
  id        String   @id @default(cuid())
  name      String
  type      String
  subject   String?
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
