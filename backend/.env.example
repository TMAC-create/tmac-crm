PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tmac_crm?schema=public
JWT_SECRET=change-this-to-a-long-random-value
JWT_EXPIRES_IN=8h
TMAC_ADMIN_EMAIL=admin@tmaccrm.local
TMAC_ADMIN_PASSWORD=ChangeMe123!

# Microsoft Outlook / Graph calendar sync
# Either MICROSOFT_* or OUTLOOK_* names are accepted by the code.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# Esendex SMS
ESENDEX_ACCOUNT_REFERENCE=
ESENDEX_USERNAME=
ESENDEX_PASSWORD=
ESENDEX_SENDER_NAME=TMAC
ESENDEX_API_BASE=https://connect.esendex.com
ESENDEX_API_KEY=
ESENDEX_API_KEY_HEADER=X-Api-Key
ESENDEX_MESSAGES_URL=https://api.esendex.co.uk/v2/messages
